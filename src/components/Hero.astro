---
import { getLangFromUrl, useTranslations, getLocalePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative min-h-screen flex items-center">
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/vista-aerea.jpg"
      alt="Camping Zingira vista aérea"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-forest/70 via-forest/50 to-forest/80"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-20 w-full">
    <div class="max-w-3xl">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-bold text-white leading-tight mb-6">
        {t('hero.title')}
      </h1>
      <p class="text-xl sm:text-2xl text-green-200 mb-8 font-light">
        {t('hero.subtitle')}
      </p>

      <!-- Season announcement banner -->
      <div class="mb-8 animate-banner">
        <div class="inline-flex flex-col sm:flex-row items-center gap-3 sm:gap-4 bg-white/15 backdrop-blur-md border border-accent/40 rounded-2xl px-6 py-4">
          <span class="flex items-center gap-2 text-white font-semibold text-lg">
            <span class="inline-block w-3 h-3 bg-green-400 rounded-full animate-pulse"></span>
            {t('hero.banner.dates')}
          </span>
          <a href={getLocalePath(lang, 'tarifas-y-reservas')} class="inline-flex items-center gap-2 px-5 py-2 bg-accent text-forest font-bold rounded-full hover:bg-yellow-400 hover:scale-105 transition-all text-base">
            {t('hero.banner.cta')}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>

      <div class="flex flex-wrap gap-4 mb-12">
        <a href={`${getLocalePath(lang)}#contacto`} class="inline-flex items-center px-8 py-3 bg-accent text-forest font-bold rounded-full hover:bg-yellow-400 transition-colors text-lg">
          {t('hero.cta')}
        </a>
        <a href={getLocalePath(lang, 'tarifas-y-reservas')} class="inline-flex items-center px-8 py-3 border-2 border-white text-white font-bold rounded-full hover:bg-white hover:text-forest transition-colors text-lg">
          {t('hero.rates')}
        </a>
      </div>
    </div>

    <!-- Feature cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8">
      <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 text-center text-white border border-white/20">
        <svg class="w-8 h-8 mx-auto mb-2 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <p class="text-sm font-semibold">{t('hero.coast')}</p>
      </div>
      <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 text-center text-white border border-white/20">
        <svg class="w-8 h-8 mx-auto mb-2 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        <p class="text-sm font-semibold">{t('hero.bungalows')}</p>
      </div>
      <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 text-center text-white border border-white/20">
        <svg class="w-8 h-8 mx-auto mb-2 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6z" />
        </svg>
        <p class="text-sm font-semibold">{t('hero.parcels')}</p>
      </div>
      <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 text-center text-white border border-white/20">
        <svg class="w-8 h-8 mx-auto mb-2 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        <p class="text-sm font-semibold">{t('hero.restaurant')}</p>
      </div>
    </div>

    <!-- Warning banner -->
    <div class="mt-8 bg-accent/90 text-forest rounded-lg p-4 text-center font-semibold text-sm">
      ⚠️ {t('hero.warning')}
    </div>
  </div>
</section>

<style>
  @keyframes bannerSlideIn {
    0% {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    60% {
      opacity: 1;
      transform: translateY(-4px) scale(1.01);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  .animate-banner {
    animation: bannerSlideIn 0.8s ease-out 0.5s both;
  }
</style>
