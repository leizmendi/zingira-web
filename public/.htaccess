# ===== SECURITY HEADERS =====
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://wubook.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; frame-src https://wubook.net https://www.google.com https://maps.google.com; connect-src 'self' https://wubook.net; font-src 'self' data:;"

# ===== BLOCK SENSITIVE FILES =====
<FilesMatch "\.(env|git|gitignore|yml|yaml|lock|md|ts|mjs|log|bak|sql|db)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Block .htaccess itself from being served
<Files .htaccess>
  Order allow,deny
  Deny from all
</Files>

# Protect analytics log
<Files "analytics.log">
  Order allow,deny
  Deny from all
</Files>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ===== ALLOW OUR OWN /api/ ENDPOINTS =====
  RewriteRule ^api/ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization},L]

  # ===== BLOCK DOTFILES AND DOTFOLDERS =====
  RewriteRule (^\.|/\.) - [F]

  # ===== BLOCK KNOWN MALICIOUS BOTS =====
  RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|SemrushBot|MJ12bot|DotBot|BLEXBot|SearchmetricsBot|PetalBot|Bytespider|GPTBot|CCBot|ClaudeBot|anthropic-ai|Scrapy|wget|curl|python-requests|Go-http-client|zgrab|masscan|Nikto|sqlmap|nmap) [NC]
  RewriteRule .* - [F,L]

  # ===== BLOCK PROBING FOR VULNERABILITIES =====
  # WordPress, PHP, common attack paths
  RewriteRule ^(wp-admin|wp-login|wp-content|wp-includes|wordpress|xmlrpc\.php) - [F,L]
  RewriteRule \.(php|asp|aspx|jsp|cgi|pl)$ - [F,L]
  RewriteRule ^(admin|administrator|phpmyadmin|pma|cpanel|webmail|cPanel|mysql) - [F,L]
  RewriteRule ^(\.env|\.git|\.svn|\.hg|\.DS_Store|Thumbs\.db) - [F,L]
  RewriteRule ^(vendor|node_modules|composer\.(json|lock)|package\.json) - [F,L]
  RewriteRule ^(backup|bak|old|temp|tmp|test|debug)/ - [F,L]
</IfModule>

# ===== BLOCK EMPTY USER AGENTS =====
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} ^$ [NC]
  RewriteRule .* - [F,L]
</IfModule>

# ===== CACHING =====
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ===== COMPRESSION =====
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ===== PREVENT DIRECTORY LISTING =====
Options -Indexes

# ===== ERROR PAGES (with logging) =====
ErrorDocument 403 /api/log404.php
ErrorDocument 404 /api/log404.php
