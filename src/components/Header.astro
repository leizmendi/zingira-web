---
import { getLangFromUrl, useTranslations, getLocalePath, getAlternateUrl, languages } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="fixed top-0 w-full z-50 bg-forest/95 backdrop-blur-sm text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href={getLocalePath(lang)} class="flex items-center gap-3">
        <img
          src="/images/logo-white.png"
          alt="Camping Zingira"
          class="h-12 w-auto"
        />
        <div class="hidden sm:block">
          <span class="text-lg font-display font-bold">Zingira</span>
          <span class="block text-xs text-green-300 -mt-1">Camping · Aia-Orio</span>
        </div>
      </a>

      <!-- Navigation (desktop) -->
      <nav class="hidden md:flex items-center gap-8">
        <a href={getLocalePath(lang)} class="hover:text-accent transition-colors font-medium">
          {t('nav.home')}
        </a>
        <a href={getLocalePath(lang, 'tarifas-y-reservas')} class="hover:text-accent transition-colors font-medium">
          {t('nav.rates')}
        </a>
        <a href={`${getLocalePath(lang)}#alojamiento`} class="hover:text-accent transition-colors font-medium">
          {t('nav.accommodation')}
        </a>
        <a href={getLocalePath(lang, 'restaurante')} class="hover:text-accent transition-colors font-medium">
          {t('nav.restaurant')}
        </a>
        <a href={getLocalePath(lang, 'como-llegar')} class="hover:text-accent transition-colors font-medium">
          {t('nav.directions')}
        </a>
        <a href={`${getLocalePath(lang)}#contacto`} class="hover:text-accent transition-colors font-medium">
          {t('nav.contact')}
        </a>
      </nav>

      <!-- Language switcher & phone -->
      <div class="flex items-center gap-4">
        <a href="tel:+34682261287" class="hidden lg:flex items-center gap-2 text-sm text-green-300 hover:text-white transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          682 261 287
        </a>

        <!-- Language selector -->
        <div class="relative group">
          <button class="flex items-center gap-1 text-sm uppercase font-medium hover:text-accent transition-colors" aria-label="Select language">
            {lang}
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute right-0 top-full mt-2 bg-white text-gray-800 rounded-lg shadow-lg py-2 min-w-[120px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            {Object.entries(languages).map(([code, name]) => (
              <a
                href={getAlternateUrl(Astro.url.pathname, code as keyof typeof languages)}
                class:list={[
                  'block px-4 py-1.5 text-sm hover:bg-green-50 transition-colors',
                  { 'font-bold text-primary': code === lang }
                ]}
              >
                {name}
              </a>
            ))}
          </div>
        </div>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-forest border-t border-green-800">
    <nav class="px-4 py-4 space-y-3">
      <a href={getLocalePath(lang)} class="block py-2 hover:text-accent transition-colors font-medium">
        {t('nav.home')}
      </a>
      <a href={getLocalePath(lang, 'tarifas-y-reservas')} class="block py-2 hover:text-accent transition-colors font-medium">
        {t('nav.rates')}
      </a>
      <a href={`${getLocalePath(lang)}#alojamiento`} class="block py-2 hover:text-accent transition-colors font-medium">
        {t('nav.accommodation')}
      </a>
      <a href={getLocalePath(lang, 'restaurante')} class="block py-2 hover:text-accent transition-colors font-medium">
        {t('nav.restaurant')}
      </a>
      <a href={getLocalePath(lang, 'como-llegar')} class="block py-2 hover:text-accent transition-colors font-medium">
        {t('nav.directions')}
      </a>
      <a href={`${getLocalePath(lang)}#contacto`} class="block py-2 hover:text-accent transition-colors font-medium">
        {t('nav.contact')}
      </a>
      <div class="flex gap-3 pt-2 border-t border-green-800">
        {Object.entries(languages).map(([code, name]) => (
          <a
            href={getAlternateUrl(Astro.url.pathname, code as keyof typeof languages)}
            class:list={[
              'text-sm px-2 py-1 rounded',
              code === lang ? 'bg-accent text-forest font-bold' : 'text-green-300 hover:text-white'
            ]}
          >
            {code.toUpperCase()}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
