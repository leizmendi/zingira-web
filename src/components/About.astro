---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section>
  <!-- Section hero -->
  <div class="relative h-48 md:h-64 flex items-center justify-center overflow-hidden">
    <img
      src="/images/parcelas.jpg"
      alt="Camping Zingira parcelas"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-forest/50"></div>
    <h2 class="relative z-10 text-3xl md:text-4xl font-display font-bold text-white text-center">
      {t('about.title')}
    </h2>
  </div>

  <!-- Content -->
  <div class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <img
          src="/images/logo.jpg"
          alt="Camping Zingira logo"
          class="w-32 h-32 mb-6 rounded-full shadow-lg"
        />
        <p class="text-lg text-gray-700 leading-relaxed mb-4">
          {t('about.text1')}
        </p>
        <p class="text-gray-600 leading-relaxed">
          {t('about.text2')}
        </p>
      </div>
      <div class="relative">
        <img
          src="/images/vista-aerea.jpg"
          alt="Camping Zingira vista aérea"
          class="rounded-2xl shadow-2xl"
        />
        <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-accent rounded-full flex items-center justify-center shadow-lg">
          <span class="text-forest font-bold text-center text-xs leading-tight px-2">20 km<br/>Donostia</span>
        </div>
      </div>
    </div>
  </div>
</section>
